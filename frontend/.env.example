NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:8000

# OAuth (Phase 2) — create apps in Google Cloud Console / GitHub Developer Settings.
# Redirect URIs: ${NEXTAUTH_URL}/api/auth/callback/google and .../github
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match backend OAUTH_INTERNAL_SECRET exactly (guards server-to-server /auth/oauth).
OAUTH_INTERNAL_SECRET=
