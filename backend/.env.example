# Neon Postgres — async driver. Get this from the Neon dashboard.
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# Provider API keys
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Ollama Cloud (hosted, OpenAI-compatible) — https://ollama.com
OLLAMA_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO

# Auth — generate strong random values, e.g. `openssl rand -hex 32`
API_KEY_SALT=
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
# Guards the server-to-server /auth/oauth endpoint. Must match the frontend
# OAUTH_INTERNAL_SECRET exactly. Leave blank to disable OAuth (endpoint 401s).
OAUTH_INTERNAL_SECRET=

# Frontend / CORS
FRONTEND_URL=http://localhost:3000

# Providers
PROVIDER_TIMEOUT_SECONDS=30
